{
  "rewrites": [
    { "source": "/", "destination": "/berita/index.html" },
    { "source": "/berita/:slug", "destination": "/api/berita?slug=:slug" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "redirects": [
    { "source": "/berita", "destination": "/", "permanent": true },
    { "source": "/berita/", "destination": "/", "permanent": true }
  ]
}
